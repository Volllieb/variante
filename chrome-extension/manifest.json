{
  "manifest_version": 3,
  "name": "variante — A/B Test Element Picker",
  "version": "1.0.0",
  "description": "Browser extension companion to the variante Figma plugin: pick an element on your live site as the target for an A/B test.",
  "homepage_url": "https://www.getvariante.com",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AB Element Picker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
