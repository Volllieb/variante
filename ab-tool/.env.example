# =============================================================
# variante — Environment Variables
# =============================================================
# Das ist die Dokumentation ALLER benötigten Env-Vars.
# KEINE Secrets hier ablegen — das ist committed!
# Secrets leben in Vercel: vercel env add <KEY> production preview
# Lokal: vercel env pull .env.local --yes
# =============================================================

# ---- Supabase (Pflicht) ----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Stripe (Pflicht) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_AGENCY=""

# ---- OpenAI (Pflicht) ----
OPENAI_API_KEY=""
# OPENAI_MAX_MONTHLY_COST="20"         # Default: 20 (Pro)
# OPENAI_MAX_MONTHLY_COST_FREE="5"     # Default: 5 (Free)
# OPENAI_MAX_MONTHLY_COST_AGENCY="60"  # Default: 60 (Agency)

# ---- Cron (Pflicht) ----
CRON_SECRET=""

# ---- Site (Pflicht) ----
NEXT_PUBLIC_SITE_URL=""

# ---- Sentry (Optional, aber empfohlen) ----
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ---- Resend (Optional — Emails) ----
RESEND_API_KEY=""
# RESEND_FROM="variante <notifications@getvariante.com>"  # Default

# ---- Upstash Redis (Optional — Rate-Limiting) ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- URLBox (Optional — Screenshots) ----
URLBOX_API_KEY=""

# ---- Temp-Session Limits (Optional) ----
# Globale Tageslimits für unauthentifizierte KI-Generierungen (Redis-basiert).
# TEMP_GEN_DAILY_GLOBAL_LIMIT="500"  # Temp-Generierungen gesamt pro Tag (Default: 500)

# ---- Loadtest (Nur Preview — NIE in Production setzen) ----
# Umgeht Per-IP-Rate-Limits auf /api/resolve + /api/event für k6
# (lib/rateLimit.ts loadtestBypass — in Production hart deaktiviert).
# LOADTEST_SECRET=""

# ---- E2E Tests (Nur lokal/CI) ----
# E2E_BASE_URL="http://localhost:3000"  # Default
# E2E_TEST_EMAIL=""
# E2E_TEST_PASSWORD="E2eTest123!"       # Default

# ---- IP-Hashing (Optional — DSGVO) ----
# Salt fuer den SHA-256-Hash der Client-IP im Rate-Limiter (lib/rateLimit.ts).
# Ohne Salt wird trotzdem gehasht, nur weniger stark. In Production setzen.
# IP_HASH_SALT=""

# ---- Sentry Client (Optional — Dashboard-Error-Tracking) ----
# NUR fuer das Dashboard, dynamisch geladen (app/dashboard/SentryInit.tsx).
# Muss NEXT_PUBLIC_ sein, um clientseitig verfuegbar zu sein.
# NEXT_PUBLIC_SENTRY_DSN=""
