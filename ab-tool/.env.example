# ── Supabase (Production) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── Stripe (TEST-Modus) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Cron-Schutz ────────────────────────────────────────────────────────────
# Pflicht für Vercel Cron Jobs (/api/cron/*). Beliebiges langes Secret.
CRON_SECRET="<random-64-char-string>"

# ── E-Mail (Winner-Benachrichtigungen) ─────────────────────────────────────
# Optional. Fehlt der Key → keine Mails, nur Event-Logging.
# RESEND_API_KEY="re_..."

# ── Upstash Redis (Rate-Limiter für Production) ────────────────────────────
# Optional. Fehlt → In-Memory-Rate-Limiter (nicht geeignet für >1 Instanz).
# UPSTASH_REDIS_REST_URL="https://<db-id>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="<read+write token>"
