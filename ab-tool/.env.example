# ── Supabase (Production) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# Monatliches Budget-Limit (USD). Default 20. /api/generate blockt bei Überschreitung.
OPENAI_MAX_MONTHLY_COST="20"

# ── Stripe (TEST-Modus) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Cron-Schutz ────────────────────────────────────────────────────────────
# Pflicht für Vercel Cron Jobs (/api/cron/*). Beliebiges langes Secret.
CRON_SECRET="<random-64-char-string>"

# ── E-Mail (Winner-Benachrichtigungen + Inbound-Agent) ──────────────────
# Optional. Fehlt der Key → keine Mails, nur Event-Logging.
# RESEND_API_KEY="re_..."
# Absender-Adresse für ausgehende Mails (Winner-Notifications + Auto-Replies)
# RESEND_FROM="hello@getvariante.com"
# Secret für Resend-Inbound-Webhook-Verifikation (Svix-Standard).
# Wird von /api/email/inbound zur Signatur-Prüfung verwendet.
# RESEND_INBOUND_SECRET="whsec_..."

# ── Upstash Redis (Rate-Limiter für Production) ────────────────────────────
# Optional. Fehlt → In-Memory-Rate-Limiter (nicht geeignet für >1 Instanz).
# UPSTASH_REDIS_REST_URL="https://<db-id>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="<read+write token>"
