{
  "buildCommand": "cd ab-tool && npm run vercel-build",
  "installCommand": "cd ab-tool && npm ci",
  "outputDirectory": "ab-tool/.next",
  "crons": [
    {
      "path": "/api/cron/check-winners",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/snapshot-stats",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-webhooks",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/cleanup-data",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
